{
  "name": "soundX",
  "version": "1.1.3",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev:web": "cd apps/web && npm run dev",
    "build:web": "cd apps/web && npm run build",
    "preview:web": "cd apps/web && npm run preview",
    "dev:app": "cd apps/app && npm run dev",
    "build:app": "cd apps/app && npm run build",
    "dev:mini": "cd apps/mini && npm run dev",
    "build:mini": "cd apps/mini && npm run build",
    "dev:api": "cd services/api && pnpm run start",
    "dev:studio": "cd services/api && pnpm run studio",
    "prisma": "cd services/api && pnpm prisma generate",
    "core:dev": "cd packages/core && pnpm run dev",
    "dev": "pnpm --filter @soundx/ws run build && pnpm --filter @soundx/services run build && pnpm --filter @soundx/utils run build && pnpm --filter @soundx/db run generate && concurrently \"pnpm --filter api run start:dev\" \"pnpm --filter sound-x run dev\"",
    "release": "node scripts/release.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mmdctjj/AudioDock"
  },
  "homepage": "https://github.com/mmdctjj/AudioDock",
  "keywords": [],
  "author": "mmdctjj <mmdctjj@gmail.com>",
  "license": "ISC",
  "dependencies": {
    "@soundx/utils": "workspace:^",
    "webdav": "^5.9.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.21.4"
    },
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "@prisma/engines",
      "@prisma/client",
      "prisma"
    ],
    "ignoredBuiltDependencies": [
      "@nestjs/core@11.1.2(@nestjs/common@11.1.2(reflect-metadata@0.2.2)(rxjs@7.8.2))(@nestjs/platform-express@11.1.2)(@nestjs/websockets@11.1.9)(reflect-metadata@0.2.2)(rxjs@7.8.2)",
      "@parcel/watcher@2.5.1",
      "@prisma/client@6.8.2(prisma@6.8.2(typescript@5.9.3))(typescript@5.9.3)",
      "@prisma/engines@6.8.2",
      "@scarf/scarf@1.4.0",
      "@swc/core@1.11.29",
      "@swc/core@1.3.96",
      "@tarojs/binding@3.6.34",
      "core-js-pure@3.42.0",
      "core-js-pure@3.47.0",
      "core-js@3.34.0",
      "electron-winstaller@5.4.0",
      "electron@39.2.3",
      "esbuild@0.21.4",
      "fsevents@1.2.13",
      "prisma@6.8.2(typescript@5.9.3)",
