{
  "module": {
    "name": "default",
    "type": "entry",
    "description": "$string:module_desc",
    "mainElement": "DefaultAbility",
    "deviceTypes": [
      "phone",
      "tablet",
      "2in1",
      "car",
      "tv"
    ],
    "deliveryWithInstall": true,
    "installationFree": false,
    "pages": "$profile:main_pages",
   "requestPermissions": [
      {
        "name": "ohos.permission.INTERNET",
        "reason": "$string:permission_internet_reason",
        "usedScene": {
          "abilities": ["DefaultAbility"],
          "when": "always"
        }
      },
      // 替换了原来的 WRITE_MEDIASTORAGE，改为读写图片视频
      {
        "name": "ohos.permission.READ_IMAGEVIDEO",
        "reason": "$string:permission_storage_reason",
        "usedScene": {
          "abilities": ["DefaultAbility"],
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.WRITE_IMAGEVIDEO",
        "reason": "$string:permission_storage_reason",
        "usedScene": {
          "abilities": ["DefaultAbility"],
          "when": "inuse"
        }
      },
      // 如果你的应用是处理音乐/音频，建议加上下面的音频权限
      {
        "name": "ohos.permission.READ_AUDIO",
        "reason": "$string:permission_storage_reason",
        "usedScene": {
          "abilities": ["DefaultAbility"],
          "when": "inuse"
        }
      },
      {
        "name": "ohos.permission.WRITE_AUDIO",
        "reason": "$string:permission_storage_reason",
        "usedScene": {
          "abilities": ["DefaultAbility"],
          "when": "inuse"
        }
      },

      {
        "name": "ohos.permission.GET_NETWORK_INFO",
        "reason": "$string:permission_network_info_reason",
        "usedScene": {
          "abilities": ["DefaultAbility"],
          "when": "always"
        }
      },
      {
        "name": "ohos.permission.NFC_TAG",
        "reason": "$string:permission_nfc_reason",
        "usedScene": {
          "abilities": ["DefaultAbility"],
          "when": "inuse"
        }
      }
    ],
    "abilities": [
      {
        "name": "DefaultAbility",
        "srcEntry": "./ets/defaultability/DefaultAbility.ets",
        "description": "$string:ability_desc",
        "icon": "$media:layered_image",
        "label": "$string:ability_label",
        "startWindowIcon": "$media:startIcon",
        "startWindowBackground": "$color:start_window_background",
        "exported": true,
        "skills": [
          {
            "entities": [
              "entity.system.home"
            ],
            "actions": [
              "ohos.want.action.home"
            ]
          }
        ]
      }
    ],
    "extensionAbilities": [
      {
        "name": "DefaultBackupAbility",
        "srcEntry": "./ets/defaultbackupability/DefaultBackupAbility.ets",
        "type": "backup",
        "exported": false,
        "metadata": [
          {
            "name": "ohos.extension.backup",
            "resource": "$profile:backup_config"
          }
        ],
      }
    ]
  }
}
