<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_history_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_rounded_bg"
  android:clipToOutline="true"
  android:outlineProvider="background">

  <ImageView
    android:id="@+id/widget_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scaleType="centerCrop" />

  <ImageView
    android:id="@+id/widget_glass"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_glass_overlay" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical">

      <FrameLayout
        android:layout_width="120dp"
        android:layout_height="120dp">

        <ImageView
          android:id="@+id/widget_cover"
          android:layout_width="120dp"
          android:layout_height="120dp"
          android:layout_gravity="center"
          android:background="@drawable/widget_cover_rounded"
          android:clipToOutline="true"
          android:scaleType="centerCrop" />
      </FrameLayout>

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:layout_marginStart="14dp">

        <TextView
          android:id="@+id/widget_title"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:gravity="center_horizontal"
          android:text="Title"
          android:textColor="@android:color/white"
          android:textSize="14sp"
          android:maxLines="1"
          android:ellipsize="end" />

        <TextView
          android:id="@+id/widget_artist"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:gravity="center_horizontal"
          android:text="Artist"
          android:textColor="#B3FFFFFF"
          android:textSize="12sp"
          android:maxLines="1"
          android:ellipsize="end" />

        <ProgressBar
          android:id="@+id/widget_progress"
          style="?android:attr/progressBarStyleHorizontal"
          android:layout_width="match_parent"
          android:layout_height="4dp"
          android:layout_marginTop="8dp"
          android:layout_marginBottom="2dp"
          android:indeterminate="false"
          android:max="1000"
          android:progress="0"
          android:progressDrawable="@drawable/widget_progress"
          android:visibility="gone" />

        <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center"
          android:layout_marginTop="6dp">

          <ImageView
            android:id="@+id/widget_prev"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_widget_prev"
            android:tint="@android:color/white" />

          <ImageView
            android:id="@+id/widget_play_pause"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:src="@drawable/ic_widget_play"
            android:tint="@android:color/white" />

          <ImageView
            android:id="@+id/widget_next"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_widget_next"
            android:tint="@android:color/white" />
        </LinearLayout>
      </LinearLayout>
    </LinearLayout>

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1"
      android:orientation="vertical"
      android:layout_marginTop="14dp">

      <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:text="听过"
        android:textColor="#CCFFFFFF"
        android:textSize="11sp"
        android:textStyle="normal" />

      <LinearLayout
        android:id="@+id/widget_history_row_1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
          android:id="@+id/widget_history_cover_1"
          android:layout_width="40dp"
          android:layout_height="40dp"
          android:background="@drawable/widget_cover_rounded_list"
          android:clipToOutline="true"
          android:scaleType="centerCrop" />

        <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:layout_marginStart="10dp"
          android:orientation="vertical">

          <TextView
            android:id="@+id/widget_history_title_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Title"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

          <TextView
            android:id="@+id/widget_history_artist_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Artist"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />
        </LinearLayout>

        <ImageView
          android:id="@+id/widget_history_play_1"
          android:layout_width="26dp"
          android:layout_height="26dp"
          android:src="@drawable/ic_widget_play"
          android:tint="@android:color/white" />
      </LinearLayout>

      <LinearLayout
        android:id="@+id/widget_history_row_2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
          android:id="@+id/widget_history_cover_2"
          android:layout_width="40dp"
          android:layout_height="40dp"
          android:background="@drawable/widget_cover_rounded_list"
          android:clipToOutline="true"
          android:scaleType="centerCrop" />

        <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:layout_marginStart="10dp"
          android:orientation="vertical">

          <TextView
            android:id="@+id/widget_history_title_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Title"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

          <TextView
            android:id="@+id/widget_history_artist_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Artist"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />
        </LinearLayout>

        <ImageView
          android:id="@+id/widget_history_play_2"
          android:layout_width="26dp"
          android:layout_height="26dp"
          android:src="@drawable/ic_widget_play"
          android:tint="@android:color/white" />
      </LinearLayout>

      <LinearLayout
        android:id="@+id/widget_history_row_3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
          android:id="@+id/widget_history_cover_3"
          android:layout_width="40dp"
          android:layout_height="40dp"
          android:background="@drawable/widget_cover_rounded_list"
          android:clipToOutline="true"
          android:scaleType="centerCrop" />

        <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:layout_marginStart="10dp"
          android:orientation="vertical">

          <TextView
            android:id="@+id/widget_history_title_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Title"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

          <TextView
            android:id="@+id/widget_history_artist_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Artist"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />
        </LinearLayout>

        <ImageView
          android:id="@+id/widget_history_play_3"
          android:layout_width="26dp"
          android:layout_height="26dp"
          android:src="@drawable/ic_widget_play"
          android:tint="@android:color/white" />
      </LinearLayout>

      <LinearLayout
        android:id="@+id/widget_history_row_4"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
          android:id="@+id/widget_history_cover_4"
          android:layout_width="40dp"
          android:layout_height="40dp"
          android:background="@drawable/widget_cover_rounded_list"
          android:clipToOutline="true"
          android:scaleType="centerCrop" />

        <LinearLayout
          android:layout_width="0dp"
          android:layout_height="wrap_content"
          android:layout_weight="1"
          android:layout_marginStart="10dp"
          android:orientation="vertical">

          <TextView
            android:id="@+id/widget_history_title_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Title"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end" />

          <TextView
            android:id="@+id/widget_history_artist_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Artist"
            android:textColor="#B3FFFFFF"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end" />
        </LinearLayout>

        <ImageView
          android:id="@+id/widget_history_play_4"
          android:layout_width="26dp"
          android:layout_height="26dp"
          android:src="@drawable/ic_widget_play"
          android:tint="@android:color/white" />
      </LinearLayout>
    </LinearLayout>
  </LinearLayout>
</FrameLayout>
