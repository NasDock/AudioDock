source 'https://cdn.cocoapods.org/'

require File.join(File.dirname(`node --print "require.resolve('expo/package.json')"`), "scripts/autolinking")
require File.join(File.dirname(`node --print "require.resolve('react-native/package.json')"`), "scripts/react_native_pods")

require 'json'
require 'fileutils'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

def ccache_enabled?(podfile_properties)
  # Environment variable takes precedence
  return ENV['USE_CCACHE'] == '1' if ENV['USE_CCACHE']
  
  # Fall back to Podfile properties
  podfile_properties['apple.ccacheEnabled'] == 'true'
end

ENV['RCT_NEW_ARCH_ENABLED'] ||= '0' if podfile_properties['newArchEnabled'] == 'false'
ENV['EX_DEV_CLIENT_NETWORK_INSPECTOR'] ||= podfile_properties['EX_DEV_CLIENT_NETWORK_INSPECTOR']
ENV['RCT_USE_RN_DEP'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
ENV['RCT_USE_PREBUILT_RNCORE'] ||= '1' if podfile_properties['ios.buildReactNativeFromSource'] != 'true' && podfile_properties['newArchEnabled'] != 'false'
platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

prepare_react_native_project!

target 'AudioDock' do
  use_expo_modules!

  if ENV['EXPO_USE_COMMUNITY_AUTOLINKING'] == '1'
    config_command = ['node', '-e', "process.argv=['', '', 'config'];require('@react-native-community/cli').run()"];
  else
    config_command = [
      'npx',
      'expo-modules-autolinking',
      'react-native-config',
      '--json',
      '--platform',
      'ios'
    ]
  end

  config = use_native_modules!(config_command)
  react_native_path = config[:reactNativePath]

  # Explicitly provide RN third-party podspecs for deps (e.g., react-native-iap)
  pod 'RCT-Folly', :podspec => File.join(react_native_path, 'third-party-podspecs', 'RCT-Folly.podspec')
  pod 'fast_float', :podspec => File.join(react_native_path, 'third-party-podspecs', 'fast_float.podspec')
  pod 'fmt', :podspec => File.join(react_native_path, 'third-party-podspecs', 'fmt.podspec')
  pod 'glog', :podspec => File.join(react_native_path, 'third-party-podspecs', 'glog.podspec')
  pod 'boost', :podspec => File.join(react_native_path, 'third-party-podspecs', 'boost.podspec')
  pod 'DoubleConversion', :podspec => File.join(react_native_path, 'third-party-podspecs', 'DoubleConversion.podspec')

  use_frameworks! :linkage => podfile_properties['ios.useFrameworks'].to_sym if podfile_properties['ios.useFrameworks']
  use_frameworks! :linkage => ENV['USE_FRAMEWORKS'].to_sym if ENV['USE_FRAMEWORKS']

  use_react_native!(
    :path => react_native_path,
    :hermes_enabled => podfile_properties['expo.jsEngine'] == nil || podfile_properties['expo.jsEngine'] == 'hermes',
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      :ccache_enabled => ccache_enabled?(podfile_properties),
    )

    # Exclude arm64 for simulator (WeChat SDK is device-only)
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
      end
    end
    installer.aggregate_targets.each do |aggregate_target|
      aggregate_target.user_project.targets.each do |target|
        target.build_configurations.each do |config|
          config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64'
        end
      end
    end

    # Add a dummy x86_64 slice to WeChat SDK to allow simulator builds under Rosetta
    wechat_lib = File.join(installer.sandbox.root, 'RCTWeChat', 'libWeChatSDK.a')
    if File.exist?(wechat_lib)
      lipo_info = `lipo -info "#{wechat_lib}"`
      unless lipo_info.include?("x86_64")
        tmp_dir = File.join(Dir.pwd, 'tmp_wechat_sim')
        FileUtils.mkdir_p(tmp_dir)
        empty_c = File.join(tmp_dir, 'empty.c')
        File.write(empty_c, "void wechat_dummy() {}")
        system("xcrun --sdk iphonesimulator clang -arch x86_64 -c #{empty_c} -o #{tmp_dir}/empty.o")
        system("libtool -static -o #{tmp_dir}/libWeChatSDK_sim.a #{tmp_dir}/empty.o")
        system("lipo -create \"#{wechat_lib}\" \"#{tmp_dir}/libWeChatSDK_sim.a\" -output \"#{wechat_lib}\"")
        FileUtils.rm_rf(tmp_dir)
      end
    end

    # Fix missing folly/synchronization/SanitizeThread.h in some RN/Folly bundles
    sanitize_header = File.join(installer.sandbox.root, 'RCT-Folly', 'folly', 'synchronization', 'SanitizeThread.h')
    FileUtils.mkdir_p(File.dirname(sanitize_header))
    File.write(sanitize_header, <<~'EOF')
        /*
         * Temporary shim for missing folly/synchronization/SanitizeThread.h
         * Provides no-op annotations when TSAN is not enabled.
         */
        #pragma once

        #include <folly/Portability.h>

        namespace folly {

        enum class annotate_rwlock_level : long {
          rdlock = 0,
          wrlock = 1,
        };

        using annotate_rwlock_cd_t = void(const char*, int, const volatile void*);
        using annotate_rwlock_ar_t = void(const char*, int, const volatile void*, long);
        using annotate_rwlock_try_acquired_t =
            void(const char*, int, const volatile void*, long, int);
        using annotate_benign_race_sized_t =
            void(const char*, int, const volatile void*, long, const char*);
        using annotate_ignore_t = void(const char*, int);

        FOLLY_ALWAYS_INLINE void annotate_rwlock_create(
            const volatile void*, const char*, int) {}
        FOLLY_ALWAYS_INLINE void annotate_rwlock_create_static(
            const volatile void*, const char*, int) {}
        FOLLY_ALWAYS_INLINE void annotate_rwlock_destroy(
            const volatile void*, const char*, int) {}
        FOLLY_ALWAYS_INLINE void annotate_rwlock_acquired(
            const volatile void*, annotate_rwlock_level, const char*, int) {}
        FOLLY_ALWAYS_INLINE void annotate_rwlock_try_acquired(
            const volatile void*, annotate_rwlock_level, bool, const char*, int) {}
        FOLLY_ALWAYS_INLINE void annotate_rwlock_released(
            const volatile void*, annotate_rwlock_level, const char*, int) {}
        FOLLY_ALWAYS_INLINE void annotate_benign_race_sized(
            const volatile void*, long, const char*, const char*, int) {}
        FOLLY_ALWAYS_INLINE void annotate_ignore_reads_begin(
            const char*, int) {}
        FOLLY_ALWAYS_INLINE void annotate_ignore_reads_end(
            const char*, int) {}
        FOLLY_ALWAYS_INLINE void annotate_ignore_writes_begin(
            const char*, int) {}
        FOLLY_ALWAYS_INLINE void annotate_ignore_writes_end(
            const char*, int) {}
        FOLLY_ALWAYS_INLINE void annotate_ignore_sync_begin(
            const char*, int) {}
        FOLLY_ALWAYS_INLINE void annotate_ignore_sync_end(
            const char*, int) {}

        struct annotate_ignore_thread_sanitizer_guard {
          annotate_ignore_thread_sanitizer_guard(const char*, int) {}
          ~annotate_ignore_thread_sanitizer_guard() = default;
        };

        } // namespace folly
      EOF

    relaxed_atomic_header = File.join(installer.sandbox.root, 'RCT-Folly', 'folly', 'synchronization', 'RelaxedAtomic.h')
    FileUtils.mkdir_p(File.dirname(relaxed_atomic_header))
    File.write(relaxed_atomic_header, <<~'EOF')
        /*
         * Temporary shim for missing folly/synchronization/RelaxedAtomic.h
         */
        #pragma once

        #include <atomic>

        namespace folly {

        template <typename T>
        using relaxed_atomic = std::atomic<T>;

        } // namespace folly
      EOF
  end
end
